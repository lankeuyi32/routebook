# =====================================================================
# 高德开放平台 Key —— 必填
# 申请入口：https://console.amap.com/dev/key/app
# 注意：JS API 的 Key/安全密钥 与 Web 服务 Key 必须分开申请，不要混用
# =====================================================================

# ---- 客户端：JS API（地图渲染） -------------------------------------
# 在「应用管理」中创建一把「Web 端 (JS API)」类型的 Key
# 因为是浏览器直接使用，必须以 NEXT_PUBLIC_ 开头才能在客户端访问
NEXT_PUBLIC_AMAP_KEY=your_jsapi_key_here

# ---- 客户端：JS API 安全密钥 -----------------------------------------
# 同一把 JS API Key 配套生成的「安全密钥」（2021/12/02 之后申请的 Key 必须配置）
# 仅用于浏览器加载 JSAPI 时校验，不暴露其他权限
NEXT_PUBLIC_AMAP_SECURITY_CODE=your_jsapi_security_code_here

# ---- 服务端：Web 服务 API（搜索 / 反查 / 路径规划） -----------------
# 在「应用管理」中另外创建一把「Web 服务」类型的 Key
# 此 Key 只在 Next.js Route Handler (app/api/**/route.ts) 中使用，
# 不会下发到浏览器，泄露风险低
AMAP_WEB_KEY=your_web_service_key_here

# =====================================================================
# 使用方法
#   1. 复制本文件为 .env.local（已被 .gitignore 忽略，不会进 Git）
#   2. 把上面三个变量改成自己的真实 Key
#   3. pnpm dev
# 部署到 Vercel 时，在 Project Settings -> Environment Variables 添加
# =====================================================================
